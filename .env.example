# PostgreSQL password (used by both app and db containers)
POSTGRES_PASSWORD=changeme

# Planning Center OAuth credentials
# Get these from https://api.planningcenteronline.com/oauth/applications
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=

# Fernet encryption key for token storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Public URL where this server is reachable (via Cloudflare Tunnel)
BASE_URL=https://pco-mcp.yourdomain.com
